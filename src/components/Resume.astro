---
import "../styles/global.css";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <title>Resume - Ungku Amer Iskandar</title>
    </head>
    <!-- Removed justify-center to allow natural scrolling for a longer document  -->
    <body
        class="bg-[#F8F9FA] text-gray-900 font-mono min-h-screen flex flex-col items-center p-8 md:p-16 selection:bg-gray-300"
    >
        <div class="max-w-4xl w-full flex flex-col gap-12 md:gap-16">
            <!-- Header -->
            <header>
                <h1
                    class="text-4xl md:text-6xl font-bold tracking-tight mb-6 text-black"
                >
                    Ungku Amer Iskandar
                </h1>
                <ul
                    class="flex flex-col sm:flex-row gap-4 sm:gap-8 text-sm md:text-base text-gray-700"
                >
                    <li>
                        <a
                            href="mailto:ungkuamer@gmail.com"
                            class="hover:text-black hover:underline underline-offset-4 decoration-gray-400 transition-colors"
                        >
                            ungkuamer@gmail.com
                        </a>
                    </li>
                    <li>
                        <a
                            href="https://github.com/ungkuamer"
                            class="hover:text-black hover:underline underline-offset-4 decoration-gray-400 transition-colors"
                        >
                            Github: ungkuamer
                        </a>
                    </li>
                    <li>
                        <a
                            href="#"
                            class="hover:text-black hover:underline underline-offset-4 decoration-gray-400 transition-colors"
                        >
                            LinkedIn: Ungku Amer Iskandar
                        </a>
                    </li>
                </ul>
            </header>

            <div class="border-b-4 border-dotted border-gray-300 w-full"></div>

            <!-- Experience -->
            <section>
                <h2
                    class="text-2xl font-bold mb-6 text-black uppercase tracking-wider"
                >
                    Experience
                </h2>
                <div
                    class="space-y-10 text-gray-800 xs:text-xs sm:text-sm md:text-base"
                >
                    <!-- Job 1 -->
                    <div>
                        <div
                            class="flex flex-col sm:flex-row sm:justify-between mb-1"
                        >
                            <h3 class="font-bold text-lg text-black">
                                Freelance Web Developer
                            </h3>
                            <span class="text-gray-600"
                                >April 2026 - Current
                            </span>
                        </div>
                        <p class="mb-4 italic">
                            Full Stack Development | Remote
                        </p>
                        <ul class="list-disc list-outside ml-5 space-y-2">
                            <li>
                                Produced functional requirements and technical
                                specifications based on client brief allowing
                                for ideas from non-technical client to be
                                translated into documentation ready for
                                developer implementation.
                            </li>
                            <li>
                                Produced full stack and production ready web
                                apps including testing, authentication, design,
                                payment gateway implementation and live
                                deployment.
                            </li>
                            <li>
                                Developed battle tested, documentation ready,
                                set of workflows for agentic Al which is used to
                                help ensure alignment with the developer, speed
                                up workflow and write documentations.
                            </li>
                        </ul>
                    </div>

                    <!-- Job 2 -->
                    <div>
                        <div
                            class="flex flex-col sm:flex-row sm:justify-between mb-1"
                        >
                            <h3 class="font-bold text-lg text-black">
                                Web Development Executive
                            </h3>
                            <span class="text-gray-600"
                                >January 2023 - April 2026
                            </span>
                        </div>
                        <p class="mb-4 italic">
                            Malaysian Youth Robotics & Technology Association -
                            MyRobotech | Remote
                        </p>
                        <ul class="list-disc list-outside ml-5 space-y-2">
                            <li>
                                Voluntary work in a Non Government Organisation
                                (NGO) that aims to promote and empower Malaysian
                                youths in Science and Technology by organising
                                competitions and holding talks on relevant
                                subjects nationwide.
                            </li>
                            <li>
                                Designed and deployed a Wordpress website used
                                volunteers and participants, improving event
                                information access and onboarding.
                            </li>
                            <li>
                                Managed and helped with setting up volunteer's
                                corporate email account using M365 for
                                Nonprofits and migrated the organisation's
                                productivity suite to Google Workspace for
                                Nonprofits.
                            </li>
                        </ul>
                    </div>
                </div>
            </section>

            <!-- Education -->
            <section>
                <h2
                    class="text-2xl font-bold mb-6 text-black uppercase tracking-wider"
                >
                    Education
                </h2>
                <div class="text-gray-800 xs:text-xs sm:text-sm md:text-base">
                    <div
                        class="flex flex-col sm:flex-row sm:justify-between mb-1"
                    >
                        <h3 class="font-bold text-lg text-black">
                            University of Leeds
                        </h3>
                        <span class="text-gray-600"
                            >September 2022 - July 2026
                        </span>
                    </div>
                    <p class="mb-4 italic">
                        Master of Engineering (MEng) in Computer Science with
                        Artificial Intelligence | Leeds, United Kingdom
                    </p>
                    <ul class="list-disc list-outside ml-5 space-y-2">
                        <li>Expected Graduation: July 2026</li>
                        <li>Expected Grade: (2:1) Upper Second Class</li>
                        <li>
                            Relevant Modules: Machine Learning, Deep Learning,
                            Distributed Systems, Algorithms & Data Structures,
                            Software Engineering, Cloud Computing.
                        </li>
                    </ul>
                </div>
            </section>

            <!-- Projects -->
            <section>
                <h2
                    class="text-2xl font-bold mb-6 text-black uppercase tracking-wider"
                >
                    Projects & Research
                </h2>
                <div
                    class="space-y-10 text-gray-800 xs:text-xs sm:text-sm md:text-base"
                >
                    <div>
                        <h3 class="font-bold text-lg text-black mb-2">
                            Reducing the Latency of the UK Multimodal Public
                            Transport System
                        </h3>
                        <ul class="list-disc list-outside ml-5 space-y-2">
                            <li>
                                A postgraduate group research project focusing
                                on developing a system and algorithm to generate
                                new transport lines that could reduce the total
                                time taken of the overall journey.
                            </li>
                            <li>
                                Developed a frontend web app using React and
                                Tailwind to interact with the routing engine and
                                algorithm and modified existing routing engine
                                (Valhalla) to work with custom transport graphs
                                built from open source data.
                            </li>
                            <li>
                                <strong>Relevant skills:</strong> Graphs, API Design,
                                Frontend, Version Control.
                            </li>
                        </ul>
                    </div>

                    <div>
                        <h3 class="font-bold text-lg text-black mb-2">
                            Bike Path Network Expansion Optimisation using
                            Reinforcement Learning
                        </h3>
                        <ul class="list-disc list-outside ml-5 space-y-2">
                            <li>
                                An undergraduate research project focusing on
                                developing a framework to assist city planners
                                in giving suggestions on bike path network
                                expansions.
                            </li>
                            <li>
                                Developed and optimised a reinforcement learning
                                framework that produces suggestions on bike path
                                network expansion, engineered a custom reward
                                function based on connectivity, path efficiency,
                                population served and budget used and created
                                graphs that represents city road networks based
                                on OSM data.
                            </li>
                            <li>
                                <strong>Relevant skills:</strong> Reinforcement Learning,
                                Model Training Optimisation, Graphs.
                            </li>
                        </ul>
                    </div>

                    <div>
                        <h3 class="font-bold text-lg text-black mb-2">
                            RouteRush
                        </h3>
                        <ul class="list-disc list-outside ml-5 space-y-2">
                            <li>
                                A software engineering group project tasked with
                                producing a mock subscription based web app that
                                provide users with the ability to view and
                                manage GPS route data.
                            </li>
                            <li>
                                Processed the raw GPX file data to allow for on
                                app display, implemented a payment gateway using
                                Stripe to enable user subscription and
                                spearheaded an Agile development process by
                                facilitating bi-weekly sprint planning and task
                                distribution for a team of students.
                            </li>
                            <li>
                                <strong>Relevant skills:</strong> Management, API
                                Design, Stripe API, Version Control, Cloud Storage
                                (Bucket).
                            </li>
                        </ul>
                    </div>

                    <div>
                        <h3 class="font-bold text-lg text-black mb-2">
                            Personal Home Lab
                        </h3>
                        <ul class="list-disc list-outside ml-5 space-y-2">
                            <li>
                                A personal project focused on experimenting,
                                deploying and managing a high-availability
                                private cloud environment for network services,
                                IoT automation and media streaming.
                            </li>
                            <li>
                                Virtualised a primary server using Proxmox VE
                                and configured a Raspberry Pi as a secondary
                                node to ensure network redundancy. Implemented a
                                failover Pi-Hole configuration to maintain DNS
                                availability and network wide ad-blocking.
                            </li>
                            <li>
                                Orchestrated containerised microservices using
                                Docker with Prometheus and Grafana to visualise
                                real time system metrics and deployed a Home
                                Assistant instance for local automation.
                            </li>
                            <li>
                                <strong>Relevant skills:</strong> Virtualisation,
                                Containerisation (Docker), Network Administration.
                            </li>
                        </ul>
                    </div>
                </div>
            </section>

            <!-- Skills -->
            <section>
                <h2
                    class="text-2xl font-bold mb-6 text-black uppercase tracking-wider"
                >
                    Skills
                </h2>
                <div
                    class="space-y-2 text-gray-800 xs:text-xs sm:text-sm md:text-base"
                >
                    <p>
                        <strong>Human Languages:</strong> English, Malay.
                    </p>
                    <p>
                        <strong>Languages:</strong> Python, JavaScript, Typescript,
                        Java, C, CSS (Tailwind), SQL (MySQL), Postgres.
                    </p>
                    <p>
                        <strong>Tools:</strong> Github, Linux, HPC with Slurm.
                    </p>
                    <p>
                        <strong>ML/AI:</strong> PyTorch, stable-baselines3, Gymnasium.
                    </p>
                    <p>
                        <strong>Data/Cloud:</strong> Spark, Hadoop, Docker, Kubernetes,
                        Firebase, Supabase, Azure.
                    </p>
                </div>
            </section>

            <div class="border-b-4 border-dotted border-gray-300 w-full mt-4">
            </div>

            <!-- Navigation back to Home -->
            <nav class="pb-8">
                <a
                    href="/"
                    class="text-lg md:text-xl text-gray-700 hover:text-black hover:underline underline-offset-8 decoration-gray-400 transition-colors"
                >
                    &larr; back to home
                </a>
            </nav>
        </div>
    </body>
</html>
