---
import "../styles/global.css";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>ua. - contact</title>
    </head>
    <body
        class="bg-[#F8F9FA] text-gray-900 font-mono min-h-screen flex flex-col justify-center items-center p-8 selection:bg-gray-300"
    >
        <!-- Wrapper matching the homepage max-width and layout rhythm -->
        <div class="max-w-4xl w-full flex flex-col gap-16 md:gap-20">
            <!-- Top Section: Title & Content -->
            <main>
                <h1
                    class="text-5xl md:text-7xl font-bold tracking-tight mb-12 text-black"
                >
                    contact.
                </h1>

                <div
                    class="space-y-6 xs:text-xs sm:text-sm md:text-lg text-gray-800"
                >
                    <p>
                        Feel free to reach out for project collaborations, job opportunities, or just to say hello.
                    </p>

                    <!-- Dynamic project specification box populated from rates estimator -->
                    <div id="selection-box" class="hidden mb-8 p-6 border-2 border-black bg-white hover:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transition-all">
                        <div class="flex justify-between items-center mb-4 pb-2 border-b border-dashed border-gray-200">
                            <span class="font-bold text-xs uppercase tracking-widest text-black">Project Interest Spec</span>
                            <button id="clear-selection" class="text-xs text-gray-400 hover:text-black cursor-pointer">[ clear ]</button>
                        </div>
                        <div class="text-sm space-y-2 text-gray-850 font-mono">
                            <p>Class: <span id="sel-type" class="font-bold text-black uppercase"></span></p>
                            <p id="sel-details-row">Details: <span id="sel-details" class="font-bold text-black"></span></p>
                            <p>Estimated Cost: <span id="sel-price" class="font-extrabold text-black"></span></p>
                        </div>
                        <div class="mt-6 pt-4 border-t border-dashed border-gray-200">
                            <a id="mail-direct-btn" href="#" class="inline-block text-xs border-2 border-black bg-black text-white hover:bg-white hover:text-black font-bold py-2 px-4 uppercase tracking-wider transition-all">
                                [ email this project spec ]
                            </a>
                        </div>
                    </div>

                    <div class="space-y-4 pt-2 font-mono">
                        <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4">
                            <span class="text-gray-400 w-24 select-none">email:</span>
                            <div class="flex items-center gap-3">
                                <a
                                    href="mailto:ungkuamer@gmail.com"
                                    class="text-black hover:underline underline-offset-4 decoration-gray-400 transition-colors"
                                >
                                    ungkuamer@gmail.com
                                </a>
                                <button
                                    id="copy-email-btn"
                                    class="text-xs text-gray-400 hover:text-black border border-dashed border-gray-300 hover:border-gray-500 px-2 py-0.5 rounded cursor-pointer transition-all select-none"
                                >
                                    [ copy ]
                                </button>
                            </div>
                        </div>

                        <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4">
                            <span class="text-gray-400 w-24 select-none">github:</span>
                            <a
                                href="https://github.com/ungkuamer"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-black hover:underline underline-offset-4 decoration-gray-400 transition-colors"
                            >
                                github.com/ungkuamer &rarr;
                            </a>
                        </div>

                        <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4">
                            <span class="text-gray-400 w-24 select-none">linkedin:</span>
                            <a
                                href="https://www.linkedin.com/in/ungku-amer-iskandar/"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-black hover:underline underline-offset-4 decoration-gray-400 transition-colors"
                            >
                                linkedin.com/in/ungku-amer-iskandar &rarr;
                            </a>
                        </div>
                    </div>

                    <!-- Dotted lines -->
                    <div class="max-w-2xl space-y-4 pt-2">
                        <div
                            class="border-b-4 border-dotted border-gray-300 w-full"
                        >
                        </div>
                    </div>
                </div>
            </main>

            <!-- Bottom Section: Navigation Links mirroring homepage style -->
            <nav>
                <ul
                    class="flex flex-col sm:flex-row gap-8 sm:gap-12 md:gap-16 text-lg md:text-xl text-gray-700"
                >
                    <li>
                        <a
                            href="/"
                            class="hover:text-black hover:underline underline-offset-8 decoration-gray-400 transition-colors"
                        >
                            home
                        </a>
                    </li>
                    <li>
                        <a
                            href="/resume"
                            class="hover:text-black hover:underline underline-offset-8 decoration-gray-400 transition-colors"
                        >
                            resume
                        </a>
                    </li>
                    <li>
                        <a
                            href="/work"
                            class="hover:text-black hover:underline underline-offset-8 decoration-gray-400 transition-colors"
                        >
                            my work and researches
                        </a>
                    </li>
                    <li>
                        <a
                            href="/pricing"
                            class="hover:text-black hover:underline underline-offset-8 decoration-gray-400 transition-colors"
                        >
                            rates
                        </a>
                    </li>
                </ul>
            </nav>
        </div>

        <script>
            // Clipboard functionality
            const copyBtn = document.getElementById('copy-email-btn');
            if (copyBtn) {
                copyBtn.addEventListener('click', () => {
                    navigator.clipboard.writeText('ungkuamer@gmail.com')
                        .then(() => {
                            const originalText = copyBtn.textContent;
                            copyBtn.textContent = '[ copied! ]';
                            copyBtn.classList.remove('text-gray-400');
                            copyBtn.classList.add('text-green-600', 'font-bold');
                            
                            setTimeout(() => {
                                copyBtn.textContent = originalText;
                                copyBtn.classList.remove('text-green-600', 'font-bold');
                                copyBtn.classList.add('text-gray-400');
                            }, 2000);
                        })
                        .catch(err => {
                            console.error('Clipboard copy failed: ', err);
                        });
                });
            }

            // Selection box URL params parsing
            function initSelectionBox() {
                const urlParams = new URLSearchParams(window.location.search);
                const project = urlParams.get('project');
                const priceParam = urlParams.get('price');

                const selectionBox = document.getElementById('selection-box');
                const selType = document.getElementById('sel-type');
                const selDetailsRow = document.getElementById('sel-details-row');
                const selDetails = document.getElementById('sel-details');
                const selPrice = document.getElementById('sel-price');
                const mailDirectBtn = document.getElementById('mail-direct-btn') as HTMLAnchorElement;
                const clearSelection = document.getElementById('clear-selection');

                if (project && selectionBox && selType && selPrice && mailDirectBtn) {
                    selectionBox.classList.remove('hidden');
                    
                    let projectLabel = '';
                    let detailsLabel = '';
                    let priceLabel = '';

                    if (project === 'static') {
                        projectLabel = 'Static Pages';
                        detailsLabel = 'Custom, responsive static pages';
                        priceLabel = 'RM 500 / page';
                    } else if (project === 'dynamic') {
                        projectLabel = 'Dynamic Site';
                        detailsLabel = 'Headless CMS integration, blog/portfolio manager';
                        priceLabel = 'RM 3,500+';
                    } else if (project === 'custom_web_app') {
                        projectLabel = 'Custom Web App';
                        detailsLabel = 'Full-stack dashboard, secure user auth, databases, payments & custom integrations';
                        priceLabel = 'RM 5,000+';
                    } else {
                        projectLabel = project.replace(/_/g, ' ');
                        detailsLabel = '';
                        priceLabel = priceParam ? priceParam.replace(/_/g, ' ') : 'TBD';
                    }

                    if (priceParam) {
                        if (priceParam === 'RM500_per_page') priceLabel = 'RM 500 / page';
                        else if (priceParam === 'RM3500_plus') priceLabel = 'RM 3,500+';
                        else if (priceParam === 'RM5000_plus') priceLabel = 'RM 5,000+';
                    }

                    selType.innerText = projectLabel;
                    if (detailsLabel && selDetails) {
                        selDetails.innerText = detailsLabel;
                        if (selDetailsRow) selDetailsRow.style.display = 'block';
                    } else {
                        if (selDetailsRow) selDetailsRow.style.display = 'none';
                    }

                    selPrice.innerText = priceLabel;

                    // Generate dynamic mailto link
                    const subject = encodeURIComponent(`Freelance Project Inquiry: ${projectLabel}`);
                    let bodyText = `Hello Amer,\n\nI visited your rates page and I'm interested in working with you on a project:\n\n- Project Type: ${projectLabel}\n`;
                    if (detailsLabel) {
                        bodyText += `- Description: ${detailsLabel}\n`;
                    }
                    bodyText += `- Rates Package: ${priceLabel}\n\nHere are some details about what I want to build:\n\n[ Describe your project goals, pages, and key features here... ]\n\nLooking forward to hearing from you!`;
                    
                    mailDirectBtn.href = `mailto:ungkuamer@gmail.com?subject=${subject}&body=${encodeURIComponent(bodyText)}`;

                    if (clearSelection) {
                        clearSelection.addEventListener('click', () => {
                            selectionBox.classList.add('hidden');
                            // Clear URL params without reloading page
                            const cleanUrl = window.location.protocol + "//" + window.location.host + window.location.pathname;
                            window.history.replaceState({ path: cleanUrl }, '', cleanUrl);
                        });
                    }
                }
            }

            initSelectionBox();
            document.addEventListener('astro:page-load', initSelectionBox);
        </script>
    </body>
</html>
