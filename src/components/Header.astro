---
import ThemeToggle from "./ThemeToggle.astro";
import "../styles/global.css";
---

<header class="w-full border-b-4 border-black bg-[#F8F9FA] dark:bg-[#080c14] sticky top-0 z-40">
  <div class="max-w-4xl mx-auto px-6 py-4 flex flex-row justify-between items-center">
    <!-- Brand / Home Logo -->
    <a
      href="/"
      class="font-mono font-bold text-2xl tracking-tight text-black hover:text-gray-600 dark:hover:text-[#38bdf8] transition-colors select-none"
    >
      ua.
    </a>

    <!-- Navigation Menu & Theme Toggle -->
    <div class="flex items-center gap-6 sm:gap-8">
      <nav class="font-mono text-xs sm:text-sm font-bold uppercase tracking-wider">
        <ul class="flex gap-4 sm:gap-6 text-gray-700 items-center">
          <li>
            <a
              href="/work"
              class="hover:text-black hover:underline underline-offset-8 decoration-gray-400 transition-colors"
            >
              work
            </a>
          </li>
          <li>
            <a
              href="/resume"
              class="hover:text-black hover:underline underline-offset-8 decoration-gray-400 transition-colors"
            >
              resume
            </a>
          </li>
          <li>
            <a
              href="/pricing"
              class="hover:text-black hover:underline underline-offset-8 decoration-gray-400 transition-colors"
            >
              rates
            </a>
          </li>
          <li>
            <a
              href="/contact"
              class="hover:text-black hover:underline underline-offset-8 decoration-gray-400 transition-colors"
            >
              contact
            </a>
          </li>
        </ul>
      </nav>

      <!-- Theme Toggle inline trigger -->
      <ThemeToggle />
    </div>
  </div>
</header>
